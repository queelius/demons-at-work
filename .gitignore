# LaTeX build artifacts
*.aux
*.log
*.out
*.toc
*.bbl
*.blg
*.lof
*.lot
*.fls
*.fdb_latexmk
*.synctex.gz
*.latexml.log
chapters/*.aux

# KDP paperback interior build (intermediate; regenerated by `make paperback`)
*_paperback.tex
*_paperback.pdf

# HTML output (generated by `make html` via tex2html)
docs/

# Editor / OS
*.swp
*~
.DS_Store

# Browser-automation session artifacts (Playwright snapshots)
.playwright-mcp/

# Plugin-local working notes (the cover assets in kdp/ are tracked)
.claude/

# Raw pre-processed vignette art (regenerable via art/generate_vignettes.py;
# the post-processed *.png that the build uses as chapter ornaments are tracked)
art/vignettes/*_raw.png
